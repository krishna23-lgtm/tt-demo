{
  "info": {
    "name": "Watch Together OTT Platform",
    "description": "REST examples for the techtankDemo backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "roomId",
      "value": "ABCD1234"
    }
  ],
  "item": [
    {
      "name": "Create Room",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/rooms",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "rooms"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"movieId\": \"movie123\",\n  \"hostId\": \"user1\",\n  \"hostName\": \"Ram\"\n}"
        }
      }
    },
    {
      "name": "Join Room",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/rooms/{{roomId}}/join",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "rooms",
            "{{roomId}}",
            "join"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"user2\",\n  \"userName\": \"Aman\"\n}"
        }
      }
    },
    {
      "name": "Get Room",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/rooms/{{roomId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "rooms",
            "{{roomId}}"
          ]
        }
      }
    },
    {
      "name": "Leave Room",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/rooms/{{roomId}}/leave",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "rooms",
            "{{roomId}}",
            "leave"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"user1\"\n}"
        }
      }
    }
  ]
}
